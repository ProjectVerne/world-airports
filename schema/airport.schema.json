{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ProjectVerne/world-airports/schema/airport.schema.json",
  "title": "Airport (v2)",
  "description": "One physical airport. See SCHEMA.md for prose and ARCHITECTURE.md for rationale.",
  "type": "object",
  "additionalProperties": false,
  "required": ["key", "codes", "name", "type", "status", "location", "keywords", "metadata"],
  "properties": {
    "key": {
      "type": "string",
      "description": "Stable, immutable, opaque identity. Equals the filename stem.",
      "pattern": "^([a-z]{4}|_[a-z]{2}_[0-9]+)$"
    },
    "codes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["icao", "iata", "gps", "local"],
      "properties": {
        "icao": { "type": ["string", "null"], "pattern": "^[A-Z0-9]{4}$" },
        "iata": { "type": ["string", "null"], "pattern": "^[A-Z0-9]{3}$" },
        "gps": { "type": ["string", "null"], "pattern": "^[A-Z0-9]{3,4}$" },
        "local": { "type": ["string", "null"], "minLength": 1, "maxLength": 12 }
      }
    },
    "name": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": ["large_airport", "medium_airport", "small_airport", "heliport", "seaplane_base", "balloonport", "closed"]
    },
    "status": {
      "type": "string",
      "enum": ["open", "closed", "construction", "abandoned"]
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["latitude", "longitude", "elevation_ft", "iso_country", "iso_region", "municipality"],
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
        "elevation_ft": { "type": "number" },
        "iso_country": { "type": "string", "pattern": "^[A-Z]{2}$" },
        "iso_region": { "type": "string", "minLength": 1 },
        "municipality": { "type": ["string", "null"] }
      }
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "wikipedia": { "type": ["string", "null"] },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created", "updated", "sources", "curated"],
      "properties": {
        "created": { "type": "string", "format": "date" },
        "updated": { "type": "string", "format": "date" },
        "sources": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "curated": { "type": "boolean" },
        "source_id": { "type": "number" },
        "supersedes": { "type": ["string", "null"] },
        "superseded_by": { "type": ["string", "null"] }
      }
    }
  }
}
